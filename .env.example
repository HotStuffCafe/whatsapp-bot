# Payment mode: false | payonly | paycod
ENABLE_PAYMENT=paycod

# Google credentials: set JSON inline (raw JSON or base64 JSON)
GOOGLE_CREDS_JSON=
# Alternative file-based credentials (optional)
GOOGLE_CREDS_FILE=
GOOGLE_APPLICATION_CREDENTIALS=

# Google Sheets target
ORDER_SHEET_ID=
# Optional fallback if ORDER_SHEET_ID is not set
ORDER_SHEET_NAME=ORDER
ORDER_WORKSHEET=ORDER
PAYLOAD_WORKSHEET=PAYLOAD

# Razorpay
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=
RAZORPAY_CALLBACK_URL=https://<your-domain>/payment/callback_uat1.1

# Optional
OPENAI_API_KEY=
